<lccdd>

  <define>
    <comment> Primary directions for the tracker </comment>
    <comment> TODO: use actual design angles rather than calculated projective directions </comment>
    <comment> projective cone at 45 degree </comment>
    <constant name="TrackerPrimaryAngle"             value="atan(1)" />
    <constant name="TrackerForwardAngle"             value="2*atan(exp(-1.6472))" />
    <constant name="TrackerBackwardAngle"            value="2*atan(exp(-1.5166))" />

    <comment> Main parameters for the vertex tracker </comment>
    <constant name="VertexBarrel_length"             value="26.6*cm"/>
    <constant name="VertexBarrel_rmin"               value="3.6*cm"/>
    <constant name="VertexBarrel_rmax"               value="13.0*cm"/>

    <comment> Main parameters for the SiBarrel layer geometry </comment>
    <constant name="SiBarrel1_rmin"                  value="25.9*cm"/>
    <constant name="SiBarrel2_rmin"                  value="41.4*cm"/>
    <constant name="SiBarrel_angle"                  value="TrackerPrimaryAngle"/>
    <constant name="SiBarrel_dz"                     value="2*cm"/>

    <comment> Main parameters for the Si Endcaps geometry </comment>

    <constant name="TrackerEndcapDisk_rmax"         value="43*cm"/>

    <comment> Main parameters for the Outer MPGD barrel layer </comment>
    <constant name="MPGDOuterBarrelModule_rmin"      value="730*mm"/>
    <constant name="MPGDOuterBarrelModule_zmin1"     value="1925*mm"/> <comment> negative z </comment>
    <constant name="MPGDOuterBarrelModule_zmin2"     value="1675*mm"/> <comment> positive z </comment>

    <comment> Main parameters for the Inner MPGD barrel layer </comment>
    <constant name="InnerMPGDBarrel_rmin"            value="555*mm"/>
    <constant name="InnerMPGDBarrel_rmax"            value="615*mm"/>
    <constant name="InnerMPGDBarrel_dz"              value="0"/>
    <constant name="InnerMPGDBarrel_zmin"            value="1025*mm"/> <comment> negative z </comment>
    <constant name="InnerMPGDBarrel_zmax"            value="1450*mm"/> <comment> positive z </comment>
    <constant name="InnerMPGDBarrel_length"          value="InnerMPGDBarrel_zmax + InnerMPGDBarrel_zmin"/>
    <constant name="InnerMPGDBarrel_zoffset"         value="0.5*(InnerMPGDBarrel_zmax - InnerMPGDBarrel_zmin)"/>

    <comment> Main parameters for Barrel TOF layers </comment>
    <comment> Barrel TOF region </comment>
    <constant name="BarrelTOF1_zmin"          value="112.5*cm"/>
    <constant name="BarrelTOF1_zmax"          value="17.25*cm"/>
    <constant name="BarrelTOF2_zmin"           value="-17.75*cm"/>
    <constant name="BarrelTOF2_zmax"           value="147.5*cm"/>

    <constant name="BarrelTOF_radius_design" value="64.6*cm"/>

    <comment> Forward TOF region  </comment>
    <constant name="ForwardTOFRegion_zmin"        value="174.0*cm" />
    <constant name="ForwardTOFRegion_tan"         value="CentralTrackingRegionP_tan" />
    <constant name="ForwardTOFRegion_minR"        value="9.5*cm" />
    <constant name="ForwardTOFRegion_maxR"        value="60.5*cm" />
    <constant name="ForwardTOF_xOffset"           value="-2.75*cm" />
    <constant name="ForwardTOF_det_height"        value="2.0*cm" />
    <constant name="ForwardTOF_length"            value="min(ForwardTOFRegion_length, 2.*cm)"/>
    <constant name="ForwardTOF_zmin"              value="ForwardTOFRegion_zmin + ForwardTOFRegion_length - ForwardTOF_length - 1*cm"/>

    <comment> Service/Support setup </comment>
    <constant name="PST_support_tube_rmin"   value=" 535*mm"/>
    <constant name="TrackerSupportCyl_rmin1"          value="PST_support_tube_rmin"/> <comment> Ref:  SVT PST Drawing PACKET SEP 2025.pdf</comment>
    <constant name="TrackerSupportCylEndcapN_rmin2"   value="BackwardPIDRegion_rmax + 4.5*cm"/> <comment> Ref: Services Material Budget 24.03.13.stp -- 670.00 mm, nudged 5 mm </comment>
    <constant name="TrackerSupportCylEndcapP_rmin2"   value="ForwardTOFRegion_maxR + 2*cm"/> <comment> Ref: Services Material Budget 24.03.04..stp -- 520.00 mm </comment>
    <comment> These may belong in definitions.xml </comment>
    <constant name="InnerTrackerEndcapP_zmax"        value="CentralTrackingRegionP_zmax"/>
    <constant name="InnerTrackerEndcapN_zmax"        value="CentralTrackingRegionN_zmax"/>

    <comment> Main parameters for the silicon disks </comment>
    <comment>  5cm thickness per endcap including room for corrugation and support structures.   </comment>
    <constant name="SiTrackerEndcapLayer_thickness" value="50*mm" />
    <comment> Scalar inner cutoffs are derived from the two-circle beampipe opening plus the bakeout buffer </comment>
    <constant name="Beampipe_bakeout_buffer"        value="5*mm" />
    <comment>
      The beampipe opening constants below are evaluated at the disk face nearest the IP:
      z_eval = z_center + SiTrackerEndcapLayer_thickness/2 on +z,
      z_eval = z_center - SiTrackerEndcapLayer_thickness/2 on -z.
      This avoids overlaps when the disk layer thickness is increased.
    </comment>


    <comment> Inner tracker beampipe openings, hadron side (+z) and reflected electron side (-z) </comment>
    <constant name="InnerTrackerEndcapP_lepton_center_x" value="0.0*mm" />
    <constant name="InnerTrackerEndcapP_lepton_center_y" value="0.0*mm" />
    <constant name="InnerTrackerEndcapP_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="InnerTrackerEndcapP_hadron_center_x" value="0.0*mm" />
    <constant name="InnerTrackerEndcapP_hadron_center_y" value="0.0*mm" />
    <constant name="InnerTrackerEndcapP_hadron_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />

    <constant name="InnerTrackerEndcapN_lepton_center_x" value="0.0*mm" />
    <constant name="InnerTrackerEndcapN_lepton_center_y" value="0.0*mm" />
    <constant name="InnerTrackerEndcapN_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="InnerTrackerEndcapN_hadron_center_x" value="0.0*mm" />
    <constant name="InnerTrackerEndcapN_hadron_center_y" value="0.0*mm" />
    <constant name="InnerTrackerEndcapN_hadron_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />

    <constant name="InnerTrackerEndcapP_zmin"        value="25.0*cm" />
    <constant name="InnerTrackerEndcapP_rmin"        value="max(abs(InnerTrackerEndcapP_lepton_center_x) + InnerTrackerEndcapP_lepton_radius, abs(InnerTrackerEndcapP_hadron_center_x) + InnerTrackerEndcapP_hadron_radius)" />
    <constant name="InnerTrackerEndcapP_rmax"        value="24.0*cm" />

    <comment> Positive disk openings from the two-circle beampipe helper </comment>
    <constant name="TrackerEndcapPDisk1_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk1_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk1_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapPDisk1_hadron_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk1_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk1_hadron_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />

    <constant name="TrackerEndcapPDisk1_zmin"        value="45.0*cm" />
    <constant name="TrackerEndcapPDisk1_rmin"        value="max(abs(TrackerEndcapPDisk1_lepton_center_x) + TrackerEndcapPDisk1_lepton_radius, abs(TrackerEndcapPDisk1_hadron_center_x) + TrackerEndcapPDisk1_hadron_radius)" />
    <constant name="TrackerEndcapPDisk1_rmax"        value="TrackerEndcapDisk_rmax - 15*mm" />

    <constant name="TrackerEndcapPDisk2_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk2_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk2_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapPDisk2_hadron_center_x" value="-1.440*mm" />
    <constant name="TrackerEndcapPDisk2_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk2_hadron_radius"   value="35.488*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapPDisk2_zmin"        value="70.0*cm" />
    <constant name="TrackerEndcapPDisk2_rmin"        value="max(abs(TrackerEndcapPDisk2_lepton_center_x) + TrackerEndcapPDisk2_lepton_radius, abs(TrackerEndcapPDisk2_hadron_center_x) + TrackerEndcapPDisk2_hadron_radius)" />
    <constant name="TrackerEndcapPDisk2_rmax"        value="TrackerEndcapDisk_rmax * .98" />

    <constant name="TrackerEndcapPDisk3_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk3_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk3_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapPDisk3_hadron_center_x" value="-7.066*mm" />
    <constant name="TrackerEndcapPDisk3_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk3_hadron_radius"   value="41.111*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapPDisk3_zmin"        value="95.0*cm" />
    <constant name="TrackerEndcapPDisk3_rmin"        value="max(abs(TrackerEndcapPDisk3_lepton_center_x) + TrackerEndcapPDisk3_lepton_radius, abs(TrackerEndcapPDisk3_hadron_center_x) + TrackerEndcapPDisk3_hadron_radius)" />
    <constant name="TrackerEndcapPDisk3_rmax"        value="TrackerEndcapDisk_rmax * .98" />

    <constant name="TrackerEndcapPDisk4_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk4_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk4_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapPDisk4_hadron_center_x" value="-12.692*mm" />
    <constant name="TrackerEndcapPDisk4_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapPDisk4_hadron_radius"   value="46.734*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapPDisk4_zmin"        value="120.0*cm" />
    <constant name="TrackerEndcapPDisk4_rmin"        value="max(abs(TrackerEndcapPDisk4_lepton_center_x) + TrackerEndcapPDisk4_lepton_radius, abs(TrackerEndcapPDisk4_hadron_center_x) + TrackerEndcapPDisk4_hadron_radius)" />
    <constant name="TrackerEndcapPDisk4_rmax"        value="TrackerEndcapDisk_rmax * .98" />

    <comment> Main parameters for the negative silicon disks (will be reflected, so positive z-values here)</comment>
    <constant name="InnerTrackerEndcapN_zmin"        value="InnerTrackerEndcapP_zmin" />
    <constant name="InnerTrackerEndcapN_rmin"        value="max(abs(InnerTrackerEndcapN_lepton_center_x) + InnerTrackerEndcapN_lepton_radius, abs(InnerTrackerEndcapN_hadron_center_x) + InnerTrackerEndcapN_hadron_radius)" />
    <constant name="InnerTrackerEndcapN_rmax"        value="InnerTrackerEndcapP_rmax" />

    <comment> Negative disk openings are in reflected local-layer coordinates </comment>
    <constant name="TrackerEndcapNDisk1_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk1_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk1_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk1_hadron_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk1_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk1_hadron_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk1_zmin"        value="TrackerEndcapPDisk1_zmin" />
    <constant name="TrackerEndcapNDisk1_rmin"        value="max(abs(TrackerEndcapNDisk1_lepton_center_x) + TrackerEndcapNDisk1_lepton_radius, abs(TrackerEndcapNDisk1_hadron_center_x) + TrackerEndcapNDisk1_hadron_radius)" />
    <constant name="TrackerEndcapNDisk1_rmax"        value="TrackerEndcapPDisk1_rmax" />

    <constant name="TrackerEndcapNDisk2_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk2_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk2_lepton_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk2_hadron_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk2_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk2_hadron_radius"   value="31.757*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk2_zmin"        value="65*cm" />
    <constant name="TrackerEndcapNDisk2_rmin"        value="max(abs(TrackerEndcapNDisk2_lepton_center_x) + TrackerEndcapNDisk2_lepton_radius, abs(TrackerEndcapNDisk2_hadron_center_x) + TrackerEndcapNDisk2_hadron_radius)"   />
    <constant name="TrackerEndcapNDisk2_rmax"        value="TrackerEndcapPDisk2_rmax" />

    <constant name="TrackerEndcapNDisk3_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk3_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk3_lepton_radius"   value="33.5*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk3_hadron_center_x" value="-21.880*mm" />
    <constant name="TrackerEndcapNDisk3_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk3_hadron_radius"   value="14.285*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk3_zmin"        value="85*cm" />
    <constant name="TrackerEndcapNDisk3_rmin"        value="max(abs(TrackerEndcapNDisk3_lepton_center_x) + TrackerEndcapNDisk3_lepton_radius, abs(TrackerEndcapNDisk3_hadron_center_x) + TrackerEndcapNDisk3_hadron_radius)" />
    <constant name="TrackerEndcapNDisk3_rmax"        value="TrackerEndcapPDisk3_rmax" />

    <constant name="TrackerEndcapNDisk4_lepton_center_x" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk4_lepton_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk4_lepton_radius"   value="33.5*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk4_hadron_center_x" value="-26.130*mm" />
    <constant name="TrackerEndcapNDisk4_hadron_center_y" value="0.0*mm" />
    <constant name="TrackerEndcapNDisk4_hadron_radius"   value="14.285*mm + Beampipe_bakeout_buffer" />
    <constant name="TrackerEndcapNDisk4_zmin"        value="102*cm" />
    <constant name="TrackerEndcapNDisk4_rmin"        value="max(abs(TrackerEndcapNDisk4_lepton_center_x) + TrackerEndcapNDisk4_lepton_radius, abs(TrackerEndcapNDisk4_hadron_center_x) + TrackerEndcapNDisk4_hadron_radius)" />
    <constant name="TrackerEndcapNDisk4_rmax"        value="TrackerEndcapPDisk4_rmax" />

    <comment> Main parameters for MPGD endcap disks, offset here is the distance between disks </comment>
    <constant name="ForwardMPGD_zmin"             value="1285.0*mm"/>
    <constant name="ForwardMPGDMod_offset"        value="125.0*mm"/>
    <constant name="ForwardMPGDMod1_rmin"         value="70.0*mm" />
    <constant name="ForwardMPGDMod2_rmin"         value="70.0*mm"/>
    <comment> rmax = active area radius </comment>
    <constant name="ForwardMPGDMod1_rmax"         value="420*mm" />
    <constant name="ForwardMPGDMod2_rmax"         value="420*mm" />

    <constant name="BackwardMPGD_zmin"             value="1075.0*mm"/>
    <constant name="BackwardMPGDMod_offset"        value="125.0*mm"/>
    <constant name="BackwardMPGDMod1_rmin"         value="50.0*mm" />
    <constant name="BackwardMPGDMod2_rmin"         value="50.0*mm" />
    <comment> rmax = active area radius </comment>
    <constant name="BackwardMPGDMod1_rmax"         value="420.0*mm" />
    <constant name="BackwardMPGDMod2_rmax"         value="420.0*mm" />

  </define>
  <comment> See compact/definitions.xml for reserved detector id
    ACTS detector volume needs to be built inside out in terms of R. </comment>
  <detectors>
    <detector id="VertexSubAssembly_0_ID"
      name="VertexBarrelSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="VertexBarrel" />
    </detector>
    <detector id="TrackerSubAssembly_0_ID"
      name="InnerSiTrackerSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="InnerTrackerEndcapN"/>
      <composite name="InnerTrackerEndcapP"/>
    </detector>
    <detector id="TrackerSubAssembly_1_ID"
      name="MiddleSiBarrelSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="SagittaSiBarrel"/>
    </detector>
      <detector id="TrackerSubAssembly_1_ID"
      name="OuterSiBarrelSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="OuterSiBarrel"/>
    </detector>
    <detector id="TrackerSubAssembly_2_ID"
      name="MiddleSiEndcapSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="MiddleTrackerEndcapN"/>
      <composite name="MiddleTrackerEndcapP"/>
    </detector>
    <detector id="TrackerSubAssembly_3_ID"
      name="OuterSiEndcapSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="OuterTrackerEndcapN"/>
      <composite name="OuterTrackerEndcapP"/>
    </detector>
    <detector id="TrackerSubAssembly_4_ID"
      name="EndcapMPGDSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="BackwardMPGD"/>
      <composite name="ForwardMPGD"/>
    </detector>
    <detector id="TrackerSubAssembly_5_ID"
      name="InnerMPGDBarrelSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="InnerMPGDBarrel"/>
    </detector>
    <detector id="TrackerSubAssembly_6_ID"
      name="EndcapTOFSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="BackwardTOF"/>
      <composite name="ForwardTOF"/>
    </detector>
    <detector id="TrackerSubAssembly_7_ID"
      name="BarrelTOFSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="BarrelTOF"/>
    </detector>
    <detector id="TrackerSubAssembly_8_ID"
      name="OuterBarrelMPGDSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="MPGDOuterBarrel"/>
    </detector>
    <detector id="B0TrackerSubAssembly_ID"
      name="B0TrackerSubAssembly"
      type="DD4hep_SubdetectorAssembly"
      vis="TrackerSubAssemblyVis">
      <composite name="B0Tracker"/>
      <composite name="B0TrackerCompanion"/>
    </detector>
  </detectors>

  <documentation>
      ### Material map for ACTS
      https://eicweb.phy.anl.gov/EIC/detectors/athena/-/issues/153
  </documentation>
  <plugins>
    <plugin name="epic_FileLoader">
      <arg value="cache:$DETECTOR_PATH:/opt/detector"/>
      <arg value="file:calibrations/materials-map.cbor"/>
      <arg value="url:https://eicweb.phy.anl.gov/-/project/473/uploads/e4042d004e28ce252e969a7cde5e21b8/material-map.cbor"/>

    </plugin>
  </plugins>

</lccdd>
