<lccdd>
  <define>
    <comment>
      Main parameters
    </comment>

    <constant name="PID01RefSurf_zmin"               value="273*cm"/>
    <constant name="PID01RefSurf_zmax"               value="185*cm"/>
    <constant name="PID01RefSurf_length"             value="(PID01RefSurf_zmax + PID01RefSurf_zmin)"/>
    <constant name="PID01RefSurf_offset"             value="0.5*(PID01RefSurf_zmax - PID01RefSurf_zmin)*0"/>
    <constant name="PID01RefSurf_rmin"               value="75.5*cm"/>
    <constant name="PID01RefSurf_rmax"               value="PID01RefSurf_rmin + 10*um"/>

    <constant name="PID01RefSurfSensor_thickness"    value="1*um"/>
    <constant name="PID01RefSurfEnvelope_length"     value="PID01RefSurf_length"/>

    <comment>
      Extra parameters to approximate a cylinder as a set of skinny staves
      due to ACTS limitations.
      FIXME: this shouldn't be needed anymore, need to update the cylindrical plugin.
    </comment>
    <constant name="PID01RefSurfStave_count"         value="4*128"/>
    <constant name="PID01RefSurfStave_width"         value="2*PID01RefSurf_rmin * tan(180*degree/PID01RefSurfStave_count)"/>
  </define>

  <detectors>
    <documentation level="5">
        ### Actual detectors
    </documentation>
    <detector
      id="RefPID01_ID"
      name="PID01RefSurf"
      type="epic_RefPID01"
      readout="PID01RefHits">
      <dimensions
        rmin="PID01RefSurf_rmin"
        rmax="PID01RefSurf_rmax"
	      length="PID01RefSurf_length"/>
      <position x="0" y="0" z="PID01RefSurf_offset"/>
      <comment>Vertex Barrel Modules</comment>
      <module name="PID01RefSurf_Mod" vis="VertexLayerVis">
        <module_component name="PID01Sensor"
                          material="Silicon"
                          sensitive="true"
                          width="PID01RefSurfStave_width"
                          length="PID01RefSurf_length"
                          thickness="PID01RefSurfSensor_thickness"
                          vis="VertexLayerVis" />
      </module>
      <comment> Layers composed of many arrayed modules  </comment>
      <layer module="PID01RefSurf_Mod" id="1" vis="VertexLayerVis">
        <barrel_envelope
          inner_r="PID01RefSurf_rmin-1*um"
          outer_r="PID01RefSurf_rmax+1*um"
          z_length="PID01RefSurf_length+2*um" />
        <layer_material surface="inner" binning="binPhi,binZ" bins0="PID01RefSurfStave_count" bins1="100" />
        <comment>
          phi0     : Starting phi of first module.
          phi_tilt : Phi tilt of a module.
          rc       : Radius of the module center.
          nphi     : Number of modules in phi.
          rphi_dr  : The delta radius of every other module.
          z0       : Z position of first module in phi.
          nz       : Number of modules to place in z.
          dr       : Radial displacement parameter, of every other module.
        </comment>
        <rphi_layout phi_tilt="0.0*degree" nphi="PID01RefSurfStave_count" phi0="0.0" rc="PID01RefSurf_rmin" dr="0.0 * mm"/>
        <z_layout dr="0.0 * mm" z0="PID01RefSurf_offset" nz="1"/>
      </layer>
    </detector>
  </detectors>

  <readouts>
    <readout name="PID01RefHits">
      <segmentation type="CartesianGridXY" grid_size_x="3*mm" grid_size_y="3*mm" />
      <id>system:8,layer:4,module:12,sensor:2,x:32:-16,y:-16</id>
    </readout>
  </readouts>

</lccdd>
