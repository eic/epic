
<lccdd>

  <detectors>
    <detector
    id="BackwardsBeamline_ID"
    type="BeamPipeTracking"
    name="Pipe_tracker"
    readout="BackwardsBeamlineHits">

        <slice
        pipe_id="0"
        grandmother="Pipe_Q1eR_to_B2BeR"
        mother="Pipe_to_Q1eR_vacuum"
        name="Pipe_to_Q1eR_tracker"/>

        <slice
        pipe_id="1"
        grandmother="Pipe_Q1eR_to_B2BeR"
        mother="Pipe_in_Q1eR_vacuum"
        name="Pipe_in_Q1eR_tracker"/>

        <slice
        pipe_id="2"
        grandmother="Pipe_Q1eR_to_B2BeR"
        mother="Pipe_Q2eR_to_B2BeR_combined_vacuum"
        name="Pipe_in_Q2eR_tracker"
        use_cross_section="true"
        plane_z="Q2eR_CenterZ - Q2eR_Length/2*cos(Q2eR_Theta)"
        plane_x="Q2eR_CenterX - Q2eR_Length/2*sin(Q2eR_Theta)"
        plane_yrot="Q2eR_Theta"/>

        <slice
        pipe_id="3"
        grandmother="Pipe_Q1eR_to_B2BeR"
        mother="Pipe_Q2eR_to_B2BeR_combined_vacuum"
        name="Pipe_in_B2AeR_tracker"
        use_cross_section="true"
        plane_z="B2AeR_CenterZ - B2AeR_Length/2*cos(B2AeR_Theta)"
        plane_x="B2AeR_CenterX - B2AeR_Length/2*sin(B2AeR_Theta)"
        plane_yrot="B2AeR_Theta"/>

        <slice
        pipe_id="4"
        grandmother="BackwardsTaggerVacuum"
        mother="TaggerStation_Vacuum"
        name="Pipe_exiting_B2BeR_tracker"
        use_cross_section="true"
        plane_z="B2BeR_EndZ"
        plane_x="B2BeR_EndX"
        plane_yrot="B2BeR_Theta"/>

        <slice
        pipe_id="5"
        grandmother="Pipe_SQ3eR_to_D4eR_5"
        mother="Pipe_in_SQ3eR_vacuum"
        name="Pipe_in_SQ3eR_tracker_start"
        end="false"/>

        <slice
        pipe_id="6"
        grandmother="Pipe_SQ3eR_to_D4eR_5"
        mother="Pipe_in_SQ3eR_vacuum"
        name="Pipe_in_SQ3eR_tracker_end"/>

        <slice
        pipe_id="7"
        grandmother="Pipe_SQ3eR_to_D4eR_5"
        mother="Pipe_in_Q3eR_vacuum"
        name="Pipe_in_Q3eR_tracker_start"/>

    </detector>

    <detector
        type="BeamPipeStop"
        name="Backwards_Pipe_Stop"
        grandmother="Pipe_SQ3eR_to_D4eR_5"
        mother="Pipe_Q3eR_to_SQ4eR_vacuum"
    />

  </detectors>

  <readouts>

    <readout name="BackwardsBeamlineHits">
      <segmentation type="NoSegmentation"/>
      <id>system:8,pipe:8,end:2</id>
    </readout>

  </readouts>

</lccdd>
