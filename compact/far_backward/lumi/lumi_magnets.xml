<lccdd>

<comment>
Construct the sweeper and analyzer dipole magnets for the luminosity subsystem.
</comment>

<define>
  <constant name="LumiMag_DX_Coil"              value="168.721*cm"/>
  <constant name="LumiMag_DY_Coil"              value=" 64.871*cm"/>
  <constant name="LumiMag_DZ_Coil"              value="  7.724*cm"/>
  <constant name="LumiMag_R_Coil"               value=" 24.111*cm"/>
  <constant name="LumiMag_OffsetX_Coil"         value=" 12.862*cm"/>
  <constant name="LumiMag_DX_Coil_Apert"        value="130.100*cm"/>
  <constant name="LumiMag_DY_Coil_Apert"        value=" 26.250*cm"/>

  <constant name="LumiMag_DX_InnerBox"         	value="65.621*cm"/>
  <constant name="LumiMag_DY_InnerBox"         	value="33.448*cm"/>

  <constant name="CenterY_Bfield"              	value="0*m"/>
</define>


<detectors>
  <detector
      name="SweeperMag"
      type="LumiMagnets"
      vis_name1="AnlGreen"
      vis_name2="AnlRed"
      vis_name3="AnlGray"
      vis_name4="AnlBlue">

    <position x="LumiSweepMag_X"
              y="LumiSweepMag_Y - CenterY_Bfield"
              z="LumiSweepMag_Z" />
    <rotation x="0*rad" y="0*rad" z="0*rad" />
  
    <shielding DR="Shielding_DR"
               IR="Shielding_IR"
               DZ="Shielding_DZ"/>

    <dimensions_yoke_box x="LumiMag_DX" y="LumiMag_DY" z="LumiMagMainBody_DZ" />
    <dimensions_yoke_aperture name="aperture">
      <point x=" 0*mm" y=" (656.21*mm /2.0)"/>
      <point x=" (334.48*mm /2.0)" y=" (656.21*mm /2.0)"/>
      <point x=" (334.48*mm /2.0)" y=" (656.21*mm /2.0 - 198.11*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x=" (334.48*mm /2.0)" y="-(656.21*mm /2.0 - 198.11*mm)"/>
      <point x=" (334.48*mm /2.0)" y="-(656.21*mm /2.0)"/>
      <point x=" 0*mm" y="-(656.21*mm /2.0)"/>
      <point x="-(334.48*mm /2.0)" y="-(656.21*mm /2.0)"/>
      <point x="-(334.48*mm /2.0)" y="-(656.21*mm /2.0 - 198.11*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x="-(334.48*mm /2.0)" y=" (656.21*mm /2.0 - 198.11*mm)"/>
      <point x="-(334.48*mm /2.0)" y=" (656.21*mm /2.0)"/>
    </dimensions_yoke_aperture>

    <dimensions_coil_box x="LumiMag_DX_Coil" 
			 y="LumiMag_DY_Coil" 
			 z="LumiMag_DZ_Coil" 
			 r="LumiMag_R_Coil" 
			 dx="LumiMag_OffsetX_Coil"/>
    <dimensions_coil_aperture x="LumiMag_DX_Coil_Apert" y="LumiMag_DY_Coil_Apert" z="2*LumiMag_DZ_Coil"/> 
  </detector>

  <detector
      name="AnalyzerMag"
      type="LumiMagnets"
      vis_name1="AnlGreen"
      vis_name2="AnlRed"
      vis_name3="AnlGray"
      vis_name4="AnlBlue">

    <position x="LumiAnalyzerMag_X" 
	      y="LumiAnalyzerMag_Y - CenterY_Bfield" 
	      z="LumiAnalyzerMag_Z"/>
    <rotation x="0*rad" y="0*rad" z="0*rad" />

    <shielding DR="Shielding_DR"
               IR="Shielding_IR"
               DZ="Shielding_DZ"/>

    <dimensions_yoke_box x="LumiMag_DX" y="LumiMag_DY" z="LumiMagMainBody_DZ" />
    <dimensions_yoke_aperture name="aperture">
      <point x=" 0*mm" y=" (656.21*mm /2.0)"/>
      <point x=" (334.48*mm /2.0)" y=" (656.21*mm /2.0)"/>
      <point x=" (334.48*mm /2.0)" y=" (656.21*mm /2.0 - 198.11*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x=" (334.48*mm /2.0 - 85.36*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x=" (334.48*mm /2.0)" y="-(656.21*mm /2.0 - 198.11*mm)"/>
      <point x=" (334.48*mm /2.0)" y="-(656.21*mm /2.0)"/>
      <point x=" 0*mm" y="-(656.21*mm /2.0)"/>
      <point x="-(334.48*mm /2.0)" y="-(656.21*mm /2.0)"/>
      <point x="-(334.48*mm /2.0)" y="-(656.21*mm /2.0 - 198.11*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y="-(656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm + 5.12*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm - 16.56*mm)"/>
      <point x="-(334.48*mm /2.0 - 85.36*mm)" y=" (656.21*mm /2.0 - 198.11*mm - 31.14*mm)"/>
      <point x="-(334.48*mm /2.0)" y=" (656.21*mm /2.0 - 198.11*mm)"/>
      <point x="-(334.48*mm /2.0)" y=" (656.21*mm /2.0)"/>
    </dimensions_yoke_aperture>

    <dimensions_coil_box x="LumiMag_DX_Coil" 
			 y="LumiMag_DY_Coil" 
			 z="LumiMag_DZ_Coil" 
			 r="LumiMag_R_Coil" 
			 dx="LumiMag_OffsetX_Coil"/>
    <dimensions_coil_aperture x="LumiMag_DX_Coil_Apert" y="LumiMag_DY_Coil_Apert" z="2*LumiMag_DZ_Coil"/> 
  </detector>

</detectors>


  <comment>
  Calculated field option is the current default.
  DZ of Ideal Fields option is set to main body length, not coil length.
  </comment>


  <fields>

    <comment> Ideal fields </comment>
    <comment>
    <field name="LumiSweeperField" type="MultipoleMagnet">
      <position x="LumiSweepMag_X" y="LumiSweepMag_Y" z="LumiSweepMag_Z"/>
      <rotation x="0" y="0" z="0"/>
      <shape type="Box" dx="LumiMag_DX_InnerBox/2.0" dy="LumiMag_DY_InnerBox/2.0" dz="LumiMagMainBody_DZ/2.0"/>
      <coefficient coefficient="0" skew="LumiSweepIdealMag_B"/>
    </field>

    <field name="LumiAnalyzerField" type="MultipoleMagnet">
      <position x="LumiAnalyzerMag_X" y="LumiAnalyzerMag_Y" z="LumiAnalyzerMag_Z"/>
      <rotation x="0" y="0" z="0"/>
      <shape type="Box" dx="LumiMag_DX_InnerBox/2.0" dy="LumiMag_DY_InnerBox/2.0" dz="LumiMagMainBody_DZ/2.0"/>
      <coefficient coefficient="0" skew="LumiAnalyzerIdealMag_B"/>
    </field>
    </comment>

    <comment> Calculated fields </comment>
    <field type="epic_FieldMapB" name="LumiSweeperField" field_type="magnetic" coord_type="BxByBz"
           field_map="fieldmaps/LumiDipoleMapping_2023_09_15_XYZ_coords_cm_T.txt"
           url="https://github.com/eic/epic-data/raw/5a6bc4cd583fb3330bce475cf25b599661b902ee/LumiDipoleMapping_2023_09_15_XYZ_coords_cm_T.txt"
           cache="$DETECTOR_PATH:/opt/detector"
           scale="1.0">
      <dimensions>
        <X step="0.5*cm" min="-7.5*cm" max="7.5*cm" />
        <Y step="2.0*cm" min="-34*cm" max="34*cm" />
        <Z step="2.0*cm" min="-80*cm" max="80*cm" />
        <translationCoord x="LumiSweepMag_X" y="LumiSweepMag_Y" z="LumiSweepMag_Z" />
      </dimensions>
    </field>

    <field type="epic_FieldMapB" name="LumiAnalyzerField" field_type="magnetic" coord_type="BxByBz"
           field_map="fieldmaps/LumiDipoleMapping_2023_09_15_XYZ_coords_cm_T.txt"
           url="https://github.com/eic/epic-data/raw/5a6bc4cd583fb3330bce475cf25b599661b902ee/LumiDipoleMapping_2023_09_15_XYZ_coords_cm_T.txt"
           cache="$DETECTOR_PATH:/opt/detector"
           scale="1.0">
      <dimensions>
        <X step="0.5*cm" min="-7.5*cm" max="7.5*cm" />
        <Y step="2.0*cm" min="-34*cm" max="34*cm" />
        <Z step="2.0*cm" min="-80*cm" max="80*cm" />
        <translationCoord x="LumiAnalyzerMag_X" y="LumiAnalyzerMag_Y" z="LumiAnalyzerMag_Z" />
      </dimensions>
    </field>

  </fields>

</lccdd>
