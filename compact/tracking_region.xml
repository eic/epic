<lccdd>

  <comment>
    These are used by ddsim, the region where we store all secondaries
  </comment>

  <define>

    <comment>
      These constants are used directly by the *Geant4TCUserParticleHandler* (default in ddsim)
    </comment>
    <constant name="tracker_region_rmax"   value="EcalBarrel_rmin"/>
    <constant name="tracker_region_zmax"   value="+EcalEndcapP_zmin"/>
    <constant name="tracker_region_zmin"   value="-EcalEndcapN_zmin"/>

    <comment>
      Additional constants for the purpose of defining the additional extrusion
    </comment>
    <constant name="tracker_region_forward_extrusion_zmax"   value="38 * m"/>
    <constant name="tracker_region_forward_extrusion_rmax"   value="15 * cm"/>
    <constant name="tracker_region_forward_extrusion_rot_y"  value="ionCrossingAngle"/>

  </define>

  <comment>
    This volume is used by the *Geant4TVUserParticleHandler* (default in the latest npsim)

    Set `connected="true"` to make it visible in a geometry display
  </comment>
  <parallelworld_volume name="tracking_volume" anchor="/world" material="Air" connected="false" vis="VisibleBlue">
    <comment>
      We first build a tube using the legacy parameters and add a ion beamline extrusion
    </comment>
    <shape type="BooleanShape" operation="Union">
      <shape type="Tube" rmin="0 * cm" rmax="tracker_region_rmax" dz="(tracker_region_zmax - tracker_region_zmin) / 2" />
      <shape type="Tube" rmin="0 * cm" rmax="tracker_region_forward_extrusion_rmax" dz="tracker_region_forward_extrusion_zmax / 2" />
      <rotation x="0" y="tracker_region_forward_extrusion_rot_y" z="0" />
      <position x="sin(tracker_region_forward_extrusion_rot_y) * tracker_region_forward_extrusion_zmax / 2"
                y="0"
                z="cos(tracker_region_forward_extrusion_rot_y) * tracker_region_forward_extrusion_zmax / 2" />
    </shape>
    <position x="0" y="0" z="(tracker_region_zmax + tracker_region_zmin) / 2" />
    <rotation x="0" y="0" z="0" />
  </parallelworld_volume>

</lccdd>
