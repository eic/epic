<?xml version='1.0' encoding='utf-8'?>
<lccdd>
    
    <define>
        <comment>
            ### B0 Tracker Parameters
        </comment>
        
        <comment>
            - The detector length based on the 0.2*m step size and 4 layers.
            - I start from the downstream side of the B0 magnet and an arbitrary offset
            which puts the downstream of the detector 10cm from the end of the magnet.
        </comment>
        
        <constant name="B0Tracker_length"        value="81.0*cm" />
        <constant name="B0TrackerCenter_zpos"    value="5892.854*mm"/>
        <constant name="B0TrackerCenter_xpos"    value="-0.16000052*m" />
        <constant name="B0Tracker_rotation"      value="ionCrossingAngle" />
        
        <constant name="B0Tracker_nlayers"       value="4" />
        <constant name="B0Tracker_dz"            value="5892.854*mm"/>
        <constant name="B0TrackerLayer1_zstart"  value="0*mm"/>
        <constant name="B0TrackerLayer2_zstart"  value="269.93*mm"/>
        <constant name="B0TrackerLayer3_zstart"  value="469.54*mm"/>
        <constant name="B0TrackerLayer4_zstart"  value="809.93*mm"/>
        
        <comment>
            Basic readout module + material parameters
        </comment>
        
        <parameters>
            <parameter name="PCBMaterial"     value="Silicon" />
            <parameter name="AsicMaterial"    value="SiliconOxide" />
            <parameter name="SensorMaterial"  value="SiliconOxide" />
        </parameters>
        
        <constant name="PCBThickness"      value="2.0*mm" />
        <constant name="SensorThickness"   value="0.3*mm" />
        <constant name="AsicThickness"     value="0.3*mm" />
        
        <constant name="PCBWidth"          value="2.54*cm" />
        <constant name="PCBLength"         value="4.6*cm" />
        
        <constant name="SensorWidth"       value="1.6*cm" />
        <constant name="SensorLength"      value="1.6*cm" />
        <constant name="SensorOverlap"     value="1.0*mm" />
        
        <constant name="B0ConnectorPCBwidth"     value="2.54*cm" />
        <constant name="B0ConnectorPCBlength"    value="1.0*cm" />
        <constant name="B0ConnectorPCBThickness" value="0.425*cm" />
        
        <constant name="ASICWidth"         value="1.6*cm" />
        <constant name="ASICLength"        value="1.6*cm" />
        <constant name="ASICOverlap"       value="1.0*mm" />
        
        <!-- Support: annular sector (half-disk with inner hole) -->
        <constant name="SupportRMin"       value="3.5*cm" />
        <constant name="SupportRMax"       value="15.0*cm" />
        <!-- Optional extra radius for placement logic, not used in geometry for now -->
        <constant name="SupportRMaxInner"  value="5.0*cm" />
        <constant name="SupportThickness"  value="6.35*mm" />
        <constant name="SupportPhiStart"   value="90*deg" />
        <constant name="SupportPhiDelta"   value="180*deg" />
        
        <constant name="BackAsicSensorThickness"
        value="AsicThickness + SensorThickness" />
        <constant name="ModuleThickness"
        value="PCBThickness + BackAsicSensorThickness + 3*(AsicThickness + SensorThickness)" />
        
        <!-- Centre-to-centre offset between support disc and module stack -->
        <constant name="ModuleOffsetFromSupport"
        value="(SupportThickness + ModuleThickness)/2" />
        
    </define>
    
    <!-- ================================================================== -->
    <!-- Tracking module definition                                         -->
    <!-- ================================================================== -->
    
    <module name="TrackingUnit" vis="TrackingModule">
        <module_component name="PCB" material="Copper" vis="PCBVis">
            <box x="PCBWidth" y="PCBLength" z="PCBThickness" />
            <position x="0.0*cm" y="0.0*cm" z="0.0*cm" />
        </module_component>
        
        <module_component name="ASIC1" material="SiliconOxide" vis="ASICVis">
            <box x="ASICWidth" y="ASICLength" z="AsicThickness" />
            <position x="0.0*cm"
            y="-(PCBLength-ASICLength)/2"
            z="-(PCBThickness/2+AsicThickness/2)" />
        </module_component>
        
        <module_component name="ASIC2" material="SiliconOxide" vis="ASICVis">
            <box x="ASICWidth" y="ASICLength" z="AsicThickness" />
            <position x="0.0*cm"
            y="-(PCBLength-ASICLength)/2 + ASICLength-ASICOverlap"
            z="PCBThickness/2+AsicThickness/2" />
        </module_component>
        
        <module_component name="ASIC3" material="SiliconOxide" vis="ASICVis">
            <box x="ASICWidth" y="ASICLength" z="AsicThickness" />
            <position x="0.0*cm"
            y="-(PCBLength-ASICLength)/2 + 2*(ASICLength-ASICOverlap)"
            z="-(PCBThickness/2+AsicThickness/2)" />
        </module_component>
        
        <module_component name="Sensor1" material="SiliconOxide" vis="SensorVis" sensitive="true">
            <box x="SensorWidth" y="SensorLength" z="SensorThickness" />
            <position x="0.0*cm"
            y="-(PCBLength-SensorLength)/2"
            z="-(PCBThickness/2+AsicThickness+SensorThickness/2)" />
        </module_component>
        
        <module_component name="Sensor2" material="SiliconOxide" vis="SensorVis" sensitive="true">
            <box x="SensorWidth" y="SensorLength" z="SensorThickness" />
            <position x="0.0*cm"
            y="-(PCBLength-SensorLength)/2 + SensorLength-SensorOverlap"
            z="(PCBThickness/2+AsicThickness+SensorThickness/2)" />
        </module_component>
        
        <module_component name="Sensor3" material="SiliconOxide" vis="SensorVis" sensitive="true">
            <box x="SensorWidth" y="SensorLength" z="SensorThickness" />
            <position x="0.0*cm"
            y="-(PCBLength-SensorLength)/2 + 2*(SensorLength-SensorOverlap)"
            z="-(PCBThickness/2+AsicThickness+SensorThickness/2)" />
        </module_component>
        
	<!-- <module_component name="B0ConnectorPCB" material="SiliconOxide" vis="ConnectorPCBvis">
            <box x="B0ConnectorPCBwidth" y="B0ConnectorPCBlength" z="B0ConnectorPCBThickness" />
            <position x="0.0*cm"
            y="PCBLength/2"
            z="PCBThickness/2 + B0ConnectorPCBThickness/2" />
	</module_component>-->
    </module>
    
    <module name="B0SupportDisk" vis="B0SupportDiscVis">
      <module_component name="support" material="Copper">
        <tube rmin="SupportRMin"
              rmax="SupportRMax"
              dz="SupportThickness"
              startphi="SupportPhiStart"
              deltaphi="SupportPhiDelta"/>
      </module_component>
    </module>
    
