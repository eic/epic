<lccdd>

<define>

<constant name="FIDUCIAL_VOLUME_LENGTH" value="49.1*cm"/>
<constant name="FIDUCIAL_VOLUME_OFFSET" value="-1236.0*mm - FIDUCIAL_VOLUME_LENGTH/2"/>
<constant name="VESSEL_OUTER_RADIUS"    value="65.0*cm"/>
<constant name="SENSOR_AREA_LENGTH"     value="5.0*cm"/>

<!-- ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++ -->

<constant name="PFRICH_aerogel_thickness"  value="2.5*cm"/>                           <!-- aerogel thickness -->
<constant name="PFRICH_filter_thickness"   value="3.0*mm"/>                           <!-- filter thickness -->

<constant name="HRPPD_num_px"                 value="32"/> <!-- number of EIC HRPPD pixels along one side of the sensor -->
<constant name="HRPPD_pixel_pitch"            value="3.25*mm"/> <!-- center-to-center distance between HRPPD pixels -->

<!-- ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++ -->

<!-- Flange -->
<constant name="FLANGE_EPIPE_DIAMETER" value="10.53*cm"/>
<constant name="FLANGE_HPIPE_DIAMETER" value="4.47*cm"/>
<constant name="FLANGE_HPIPE_OFFSET"   value="6.76*cm"/>
<constant name="FLANGE_CLEARANCE"      value="0.5*cm"/>

<!-- Mirrors -->
<constant name="CONICAL_MIRROR_INNER_RADIUS" value="12.0*cm"/>
<constant name="CONICAL_MIRROR_OUTER_RADIUS" value="57.0*cm"/>
<constant name="INNER_MIRROR_THICKNESS" value="0.1*cm"/>
<constant name="OUTER_MIRROR_THICKNESS" value="0.2*cm"/>

<!-- HRPPD -->
<constant name="HRPPD_CENTRAL_ROW_OFFSET" value="4.0*cm"/>
<constant name="HRPPD_WINDOW_THICKNESS" value="0.38*cm"/>
<constant name="HRPPD_INSTALLATION_GAP" value="0.25*cm"/>
<constant name="HRPPD_CONTAINER_VOLUME_HEIGHT" value="3.2*cm"/>
<constant name="HRPPD_TILE_SIZE" value="12.0*cm"/>
<constant name="HRPPD_OPEN_AREA_SIZE" value="11.4*cm"/>
<constant name="HRPPD_ACTIVE_AREA_SIZE" value="10.8*cm"/>
<constant name="HRPPD_COLLECTION_EFFICIENCY" value="0.70"/>
<constant name="HRPPD_CERAMIC_BODY_THICKNESS" value="0.9*cm"/>
<!-- Some small number -->
<constant name="HRPPD_PHOTOCATHODE_THICKNESS" value="0.01*mm"/>
<constant name="HRPPD_BASEPLATE_THICKNESS" value="0.3*cm"/>
<constant name="HRPPD_PLATING_LAYER_THICKNESS" value="0.03*mm"/>
<constant name="EFFECTIVE_MCP_THICKNESS" value="2 * 0.06 * 0.3*cm"/>
<constant name="READOUT_PCB_THICKNESS" value="0.2*cm"/>
<constant name="READOUT_PCB_SIZE" value="HRPPD_OPEN_AREA_SIZE - 0.2*cm"/>

<!-- Aerogel -->
<constant name="AEROGEL_INNER_WALL_THICKNESS" value="0.01*cm"/>
<constant name="VESSEL_INNER_WALL_THICKNESS" value="0.29 * 2.54*cm"/>
<constant name="VESSEL_OUTER_WALL_THICKNESS" value="0.54 * 2.54*cm"/>
<constant name="VESSEL_FRONT_SIDE_THICKNESS" value="0.29 * 2.54*cm"/>
<constant name="BUILDING_BLOCK_CLEARANCE" value="0.1*cm"/>
<constant name="AEROGEL_SEPARATOR_WALL_THICKNESS" value="0.05*cm"/>
<constant name="AEROGEL_OUTER_WALL_THICKNESS" value="0.1*cm"/>

<!-- end of hardcoded constants -->
</define>

<detectors>
<detector
  id="BackwardRICH_ID"
  name="PFRICH"
  type="epic_PFRICH"

  readout="PFRICHHits"

  gas="N2cherenkov"
  material="CarbonFiber"

  vis_gas="PFRICH_gas_vis"
  >
  <type_flags type="DetType_CHERENKOV + DetType_ENDCAP"/>

<hrppd
    windowmat="QuartzOptical"
    photocathode="AirOptical"

    pcbmat="G10"
    mcpmat="SiliconDioxide"
    plating="TungstenDens25"
    ceramic="AluminumOxide"

    vis_body="HRPPD_body_vis"
    vis_pc="HRPPD_pc_vis"
    vis_window="HRPPD_window_vis"
    />

<aerogel
    material="Aerogel_PFRICH"
    vis="PFRICH_aerogel_vis"
    thickness="PFRICH_aerogel_thickness"
    />

<filter
    material="Acrylic_PFRICH"
    vis="PFRICH_filter_vis"
    thickness="PFRICH_filter_thickness"
    />

<mirror
  material="CarbonFiber"
  surface="MirrorSurface_PFRICH"
  vis="PFRICH_mirror_vis"
  />

</detector>
</detectors>

<readouts>
  <readout name="PFRICHHits">
    <segmentation
      type="CartesianGridXY"
      grid_size_x="HRPPD_pixel_pitch"
      grid_size_y="HRPPD_pixel_pitch"
      offset_x="-0.5*(HRPPD_num_px-1)*HRPPD_pixel_pitch"
      offset_y="-0.5*(HRPPD_num_px-1)*HRPPD_pixel_pitch"
      />
    <id>system:8,hrppd:12,x:32:-16,y:-16</id>
  </readout>
</readouts>

</lccdd>
